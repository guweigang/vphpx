# Knowledge Studio local environment

# Data source: demo | db
STUDIO_DATA_SOURCE=demo
APP_TIMEZONE=Asia/Shanghai

# Session
VSLIM_SESSION_SECRET=change-me-knowledge-studio

# Database
VSLIM_DB_TRANSPORT=direct
VSLIM_DB_DRIVER=mysql
VSLIM_DB_HOST=127.0.0.1
VSLIM_DB_PORT=3306
VSLIM_DB_USER=root
VSLIM_DB_PASSWORD=
VSLIM_DB_NAME=knowledge_studio
VSLIM_DB_POOL_SIZE=5
VSLIM_DB_POOL_NAME=default
VSLIM_DB_TIMEOUT_MS=1000
VSLIM_DB_UPSTREAM_SOCKET=/tmp/vhttpd_db.sock
