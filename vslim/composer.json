{
  "name": "vphpext/vslim-dev",
  "description": "Local dev/test composer root for vslim and vhttpd php package",
  "type": "project",
  "license": "MIT",
  "require-dev": {
    "php": ">=8.1",
    "vphpext/vhttpd": "dev-main"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../vhttpd/php/package",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
