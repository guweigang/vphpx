{
  "name": "vphpext/vslim-examples",
  "description": "Composer root for VSlim examples using vphpext/vhttpd package",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "vphpext/vhttpd": "dev-main"
  },
  "repositories": [
    {
      "type": "path",
      "url": "../../../vhttpd/php/package",
      "options": {
        "symlink": true
      }
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true
}
