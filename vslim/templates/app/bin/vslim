#!/usr/bin/env php
<?php
declare(strict_types=1);

$root = dirname(__DIR__);
$autoload = $root . '/vendor/autoload.php';
if (!is_file($autoload)) {
    $autoload = $root . '/../../../vhttpd/php/package/vendor/autoload.php';
}
if (is_file($autoload)) {
    require_once $autoload;
}

if (!extension_loaded('vslim')) {
    fwrite(STDERR, "vslim extension is not loaded\n");
    exit(1);
}

\VSlim\EnvLoader::bootstrap($root);

$cli = (new VSlim\Cli\App())->bootstrapDir($root);
exit($cli->runArgv($_SERVER['argv'] ?? $argv ?? []));
